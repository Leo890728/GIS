# Copy to .env and adjust. This file is read by:
#   - docker compose  (variable substitution, e.g. ${OSRM_DATA})
#   - the backend via python-dotenv when run locally (python -m backend.app)
#
# In docker-compose, each service's `environment:` already sets its own values;
# .env mainly drives OSRM_DATA and local (non-docker) runs.

# ── OSRM ──────────────────────────────────────────────────────────────────────
# Routing-graph file prefix served by the osrm container (file lives in tools/osrm/).
OSRM_DATA=taiwan-260617.osrm
# Routing algorithm; must match how OSRM_DATA was built (tools/osrm/build.sh:
# mld → partition/customize, ch → contract). CH serves /table an order of
# magnitude faster — prefer it for VRP (OSRM_DATA=taiwan-ch.osrm OSRM_ALGO=ch).
OSRM_ALGO=mld
# OSRM endpoints the backend calls. In docker these point at the osrm service
# (http://osrm:5000); locally they default to the host instance below.
HISTORY_OSRM_URL=http://localhost:5001
VRP_OSRM_URL=http://localhost:5001
HISTORY_OSRM_PROFILE=driving
HISTORY_OSRM_CONCURRENCY=16

# ── VRP OSRM client tuning ───────────────────────────────────────────────────
# Per-request timeout for /table, /nearest and route geometry calls.
VRP_OSRM_TIMEOUT_SECONDS=60
# Above this many nodes the cost matrix is fetched as parallel row×col tiles.
VRP_TABLE_SPLIT_THRESHOLD=400
# Max coordinates per tile side; an off-diagonal tile sends 2× this many
# coordinates, which must stay under osrm-routed --max-table-size (1500).
VRP_TABLE_BLOCK_MAX_COORDS=600
# Concurrent /table tile requests.
VRP_TABLE_MAX_PARALLEL_REQUESTS=8
# Concurrent /nearest requests when aggregation.snapToRoad is enabled.
VRP_SNAP_MAX_PARALLEL_REQUESTS=16
# Default solve engine when the request omits solver.engine: ortools | pyvrp.
# pyvrp (HGS) supports native multi-trip via reload depots — no disposal-clone
# cap — and typically finds better solutions in the same time budget.
VRP_SOLVER_ENGINE=ortools

# ── History capture ──────────────────────────────────────────────────────────
# 1 = this process runs the interval capture; 0 = disabled. Default when unset
# is 0 (capture is the dedicated worker's job; avoids duplicate jobs under
# multi-worker gunicorn). In docker: web=0, capture worker=1.
HISTORY_BACKGROUND_POLL=1

# ── Web server ───────────────────────────────────────────────────────────────
# The web service runs gunicorn gthread workers. With gthread, --timeout is a
# worker-heartbeat (hang) guard, not a per-request cap, so long road-smoothing
# streams are not killed for merely taking a while. Threads set how many requests
# one worker can serve concurrently (a long stream occupies one thread).
GUNICORN_TIMEOUT=120
GUNICORN_THREADS=4

# ── Native deps (defaults are the container paths; override for local installs) ─
PMTILES_BIN=/usr/local/bin/pmtiles
SPATIALITE_EXTENSION_PATH=/usr/lib/x86_64-linux-gnu/mod_spatialite.so

# ── Build-time / tooling ──────────────────────────────────────────────────────
# Frontend API base URL baked at build time; empty = same-origin (nginx proxies).
VITE_API_BASE_URL=
# go-pmtiles version installed into the backend image (Docker build arg).
PMTILES_VERSION=1.30.3
# Local tippecanoe image tag built from tools/Dockerfile.tippecanoe by the
# rebuild scripts (no GHCR dependency).
TIPPECANOE_IMAGE=tippecanoe:local
# Source extract for tools/osrm/build.sh when (re)downloading the Taiwan PBF.
PBF_URL=https://download.geofabrik.de/asia/taiwan-latest.osm.pbf
